OUTPUT_ARCH(arm)
SECTIONS
{
	. = 0x08000000;
	.text (READONLY) :
	ALIGN(4)
	{
#define X(file) file(.text);
		OBJECT_FILE_LIST
#undef X
		*(.glue_7t);
	} = 0

	/* Don't link these files' rodata for now, since it doesn't match.
	 * This needs to be fixed eventually!!! */
	/DISCARD/ :
	{

	}

	.rodata (READONLY) :
	ALIGN(4)
	{
#define X(file) file(.rodata);
		OBJECT_FILE_LIST
#undef X
	}

	.data (READONLY) :
	ALIGN(4)
	{
#define X(file) file(.data);
		OBJECT_FILE_LIST
#undef X
	}

	. = 0x02000000;
	.ewram (NOLOAD) :
	ALIGN(4)
	{
		. = 0x0;	gUnknown_02000000 = .;

	}

	. = 0x03000000;
	.iwram (NOLOAD) :
	ALIGN(4)
	{
		. = 0x00001EE0; SoundMainRAM_Buffer = .;
		. = 0x00004530; gSoundInfo = .;
		. = 0x000054E0; gMPlayJumpTable = .;
		. = 0x00005570; gCgbChans = .;
		. = 0x000057F0; gMPlayMemAccArea = .;
	} = 0

    /* Discard everything not specifically mentioned above. */
    /DISCARD/ :
    {
        *(*);
    }
}
